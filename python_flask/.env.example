# 数据库配置（生产建议 PostgreSQL）
DATABASE_URL=postgresql://username:password@host:5432/dbname

# 安全密钥
SECRET_KEY=replace-with-a-strong-secret
JWT_SECRET_KEY=replace-with-a-strong-jwt-secret

# 模型服务配置
MODEL_SERVICE_URL=https://your-model-service.example.com/predict
MODEL_ANALYZE_URL=https://your-model-service.example.com/predict

# 音频转换工具
FFMPEG_PATH=ffmpeg

# 跨域配置（逗号分隔）
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173